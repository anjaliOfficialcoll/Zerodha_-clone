# Backend environment example
# Copy this file to `.env` in the `backend/` folder and update values for your environment.

# Server port
PORT=3002

# MongoDB connection (optional). Example for local MongoDB:
MONGO_URL=mongodb://localhost:27017/zerodha_clone

# JWT signing secret — change this to a long random value in production
JWT_SECRET=change_me_to_a_long_random_secret

# Demo credentials used by the local demo login (development only)
DEMO_EMAIL=demo@demo.com
DEMO_PASS=demo
